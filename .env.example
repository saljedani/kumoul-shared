# Kumoul SHARED — Environment Configuration
# Copy this file to .env and update values

SECRET_KEY=change-this-to-a-random-secret-key-in-production
DATABASE_URL=sqlite:///instance/kumoul.db

# For PostgreSQL (production):
# DATABASE_URL=postgresql://kumoul_user:strong_password@localhost:5432/kumoul_db

# For file storage (local by default)
UPLOAD_FOLDER=app/uploads

# Session
SESSION_TIMEOUT_HOURS=8

# Flask
FLASK_ENV=production
FLASK_DEBUG=0
